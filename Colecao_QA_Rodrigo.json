  "auth": {
    "type": "bearer",
    "bearer": [
      {
        "key": "token",
        "value": "{{token}}",
        "type": "string"
      }
    ]
  },
  "event": [
    {
      "listen": "prerequest",
      "script": {
        "type": "text/javascript",
        "packages": {},
        "requests": {},
        "exec": [
          "if (!pm.environment.get(\"token\")) {\r",
          "    console.log(\"Token não encontrado. Iniciando login automático...\");\r",
          "\r",
          "    const loginRequest = {\r",
          "        url: pm.environment.get(\"baseUrl\") + '/api/login',\r",
          "        method: 'POST',\r",
          "        header: { 'Content-Type': 'application/json' },\r",
          "        body: {\r",
          "            mode: 'raw',\r",
          "            raw: JSON.stringify({\r",
          "                email: \"admin@biblioteca.com\",\r",
          "                password: \"admin123\"\r",
          "            })\r",
          "        }\r",
          "    };\r",
          "\r",
          "    pm.sendRequest(loginRequest, (err, res) => {\r",
          "        if (!err && res.code === 200) {\r",
          "            const novoToken = res.json().token;\r",
          "            const tokenLimpo = novoToken.replace(\"Bearer \", \"\").trim();\r",
          "            pm.environment.set(\"token\", tokenLimpo);\r",
          "            console.log(\"✅ Automação: Token gerado e salvo com sucesso!\");\r",
          "        } else {\r",
          "            console.log(\"❌ Erro na automação de login: \" + res.status);\r",
          "        }\r",
          "    });\r",
          "}"
        ]
      }
    },
