        {
          "name": "Cadastrar livros",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status deve ser 201\", () => {\r",
                  "    pm.response.to.have.status(201);\r",
                  "});\r",
                  "\r",
                  "var res = pm.response.json();\r",
                  "var book = res.book || res;\r",
                  "\r",
                  "if (book && book.id) {\r",
                  "    \r",
                  "    pm.environment.set(\"ultimo_id_criado\", book.id);\r",
                  "    pm.environment.set(\"ultimo_isbn_gerado\", book.isbn);\r",
                  "    pm.environment.set(\"ultima_categoria\", book.category);\r",
                  "\r",
                  "    console.log(\"✅ ID capturado: \" + book.id);\r",
                  "    console.log(\"✅ ISBN capturado: \" + book.isbn);\r",
                  "} else {\r",
                  "    console.log(\"❌ Erro: A resposta da API não contém um objeto 'book' válido.\");\r",
                  "}"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
          ],
