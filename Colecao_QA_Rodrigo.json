      "name": "Autenticação",
      "item": [
        {
          "name": "Login admin",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {\r",
                  "    let res = pm.response.json();\r",
                  "    let tokenLimpo = res.token;\r",
                  "\r",
                  "    if (tokenLimpo.startsWith(\"Bearer \")) {\r",
                  "        tokenLimpo = tokenLimpo.replace(\"Bearer \", \"\").trim();\r",
                  "    }\r",
                  "\r",
                  "    pm.environment.set(\"token\", tokenLimpo);\r",
                  "    console.log(\"✅ Token limpo e salvo!\");\r",
                  "}"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [],
            "body": {
              "mode": "raw",
              "raw": "{\r\n  \"email\": \"admin@biblioteca.com\",\r\n  \"password\": \"admin123\"\r\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "http://localhost:3000/api/login",
              "protocol": "http",
              "host": [
                "localhost"
              ],
              "port": "3000",
              "path": [
                "api",
                "login"
              ]
            }
          },
          "response": []
        }
